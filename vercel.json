{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/", "dest": "/public/login.html" },
    { "src": "/app", "dest": "/public/app.html" }
  ]
}
